---
import Logo from "./Logo.astro";
const cols = [
  {
    title: "Product",
    links: [
      { t: "Playground", h: "/play" },
      { t: "Create", h: "/create" },
      { t: "Docs", h: "/docs" },
    ],
  },
  {
    title: "Source",
    links: [
      { t: "GitHub", h: "https://github.com/hellojanpacan/hayao-js" },
      { t: "npm", h: "https://www.npmjs.com/package/hayao" },
      { t: "MIT License", h: "https://github.com/hellojanpacan/hayao-js/blob/main/LICENSE" },
    ],
  },
];
---
<footer class="border-t border-hair">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <div class="max-w-xs">
        <a
          href="/"
          class="flex items-baseline gap-2 font-display text-[1.375rem] font-semibold text-ink no-underline"
        >
          <Logo class="h-[1cap] w-[1cap]" />
          <span>Hayao<span class="text-muted">.js</span></span>
        </a>
        <p class="mt-4 font-body text-[0.95rem] font-light leading-relaxed text-soft">
          The 2D game engine for your AI agent. Deterministic, headless-native, MIT.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-12 sm:gap-20">
        {
          cols.map((col) => (
            <div>
              <p class="mb-4 font-body text-[0.7rem] uppercase tracking-[0.16em] text-muted">
                {col.title}
              </p>
              <ul class="space-y-3">
                {col.links.map((l) => (
                  <li>
                    <a
                      href={l.h}
                      class="font-body text-[0.95rem] font-light text-ink no-underline transition-colors hover:text-orange"
                    >
                      {l.t}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <p class="mt-14 font-body text-[0.85rem] font-light leading-relaxed text-soft">
      Made by, and for, creative humans with productive AI agents.
    </p>

    <div
      class="mt-6 flex flex-col gap-2 border-t border-hair pt-6 font-body text-[0.85rem] text-muted sm:flex-row sm:justify-between"
    >
      <span>© 2026 Jan Pacan · Released under the MIT License</span>
      <span class="inline-flex items-center gap-1.5">
        Built with
        <svg width="15" height="15" viewBox="0 0 24 24" fill="var(--color-orange, #e59500)" aria-hidden="true"
          ><path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path></svg
        >
        on
        <a
          href="https://astro.build"
          target="_blank"
          rel="noreferrer"
          class="text-ink no-underline transition-colors hover:text-orange">Astro</a
        >
      </span>
    </div>
  </div>
</footer>
