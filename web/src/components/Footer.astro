---
import Logo from "./Logo.astro";
const cols = [
  {
    title: "Product",
    links: [
      { t: "Playground", h: "/play" },
      { t: "Create", h: "/create" },
      { t: "Docs", h: "/docs" },
    ],
  },
  {
    title: "Source",
    links: [
      { t: "GitHub", h: "https://github.com/hellojanpacan/hayao-js" },
      { t: "npm", h: "https://www.npmjs.com/package/hayao" },
      { t: "MIT License", h: "https://github.com/hellojanpacan/hayao-js/blob/main/LICENSE" },
    ],
  },
];
---
<footer class="border-t border-hair">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <div class="max-w-xs">
        <a
          href="/"
          class="flex items-baseline gap-2 font-display text-[1.375rem] font-semibold text-ink no-underline"
        >
          <Logo class="h-[1cap] w-[1cap]" />
          <span>Hayao<span class="text-muted">.js</span></span>
        </a>
        <p class="mt-4 font-body text-[0.95rem] font-light leading-relaxed text-soft">
          The 2D game engine for your AI agent. Deterministic, headless-native, MIT.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-12 sm:gap-20">
        {
          cols.map((col) => (
            <div>
              <p class="mb-4 font-body text-[0.7rem] uppercase tracking-[0.16em] text-muted">
                {col.title}
              </p>
              <ul class="space-y-3">
                {col.links.map((l) => (
                  <li>
                    <a
                      href={l.h}
                      class="font-body text-[0.95rem] font-light text-ink no-underline transition-colors hover:text-orange"
                    >
                      {l.t}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-2 border-t border-hair pt-6 font-body text-[0.85rem] text-muted sm:flex-row sm:justify-between"
    >
      <span>© 2026 Jan Pacan · Released under the MIT License</span>
      <span>Built with Hayao.js</span>
    </div>
  </div>
</footer>
