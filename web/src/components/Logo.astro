---
/**
 * The Hayao logo. The canonical definition (paths, colors, lockup geometry)
 * lives in ./logo.ts — this component just renders it.
 *
 * `<Logo />`          — the mark alone, sized by the parent.
 * `<Logo wordmark />` — the full canonical lockup: crown + outlined "Hayao.js"
 *                       (no font dependency; theme-aware via CSS vars). Sized
 *                       by the parent too — LOCKUP_CLASS is the house default.
 */
import {
  LOGO_VIEWBOX,
  LOGO_CROWN,
  LOGO_RULE,
  LOGO_GOLD,
  WORDMARK_HAYAO,
  WORDMARK_JS,
  LOCKUP_VIEWBOX,
  LOCKUP_CLASS,
} from "./logo";

interface Props {
  class?: string;
  mono?: boolean; //     solid ink — for tiny / single-colour contexts
  wordmark?: boolean; // render the full canonical lockup
}
const { class: className = "", mono = false, wordmark = false } = Astro.props;
---
{
  wordmark ? (
    <svg viewBox={LOCKUP_VIEWBOX} class={`${LOCKUP_CLASS} ${className}`} role="img" aria-label="Hayao.js">
      <path d={LOGO_CROWN} fill={LOGO_GOLD} />
      <path d={LOGO_RULE} fill="var(--color-ink, #29335c)" />
      <path d={WORDMARK_HAYAO} fill="var(--color-ink, #29335c)" />
      <path d={WORDMARK_JS} fill="var(--color-muted, #8b90a6)" />
    </svg>
  ) : (
    <svg viewBox={LOGO_VIEWBOX} class={className} aria-hidden="true">
      <path d={LOGO_CROWN} fill={mono ? "var(--color-ink, #29335c)" : LOGO_GOLD} />
      <path d={LOGO_RULE} fill="var(--color-ink, #29335c)" />
    </svg>
  )
}
