---
/**
 * astro.build-style install box: a dark, rounded, monospace command with a
 * copy-to-clipboard button on the right. No tooltip, no primary button.
 */
const CMD = "npm i hayao";
---
<div class="install-box inline-flex items-center gap-4 rounded-2xl border border-white/10 bg-[#0f1424] py-2.5 pl-5 pr-2.5">
  <code class="font-mono text-[0.95rem] tracking-tight text-[#d7dcec]"
    ><span class="select-none text-orange">&gt;</span> {CMD}</code
  >
  <button
    type="button"
    class="copy-btn inline-flex size-9 items-center justify-center rounded-xl text-[#8ea1c7] transition-colors hover:bg-white/10 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-orange"
    aria-label="Copy install command"
    data-cmd={CMD}
  >
    <svg class="ico-copy" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>
    <svg class="ico-check" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
  </button>
</div>

<style>
  .ico-check {
    display: none;
    color: var(--color-green, #337357);
  }
  .copy-btn.copied .ico-copy {
    display: none;
  }
  .copy-btn.copied .ico-check {
    display: block;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".install-box .copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.cmd ?? "npm i hayao";
      let ok = false;
      try {
        await navigator.clipboard.writeText(text);
        ok = true;
      } catch {
        try {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          ok = document.execCommand("copy");
          ta.remove();
        } catch {
          /* clipboard unavailable */
        }
      }
      if (ok) {
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 1600);
      }
    });
  });
</script>
