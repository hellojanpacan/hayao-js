---
/**
 * `npm i hayao` chip + an info icon whose hover/focus tooltip explains what npm
 * is — for the non-technical readers whose agent runs the command for them.
 * tone="dark"  → on a light background (muted)
 * tone="light" → on a dark background (white)
 */
interface Props {
  tone?: "dark" | "light";
}
const { tone = "dark" } = Astro.props;
const codeColor = tone === "light" ? "text-white/70" : "text-muted";
const iconColor =
  tone === "light" ? "text-white/60 hover:text-white" : "text-muted hover:text-ink";
---
<span class="inline-flex items-center gap-2">
  <code class={`font-mono text-[0.9rem] ${codeColor}`}>npm i hayao</code>
  <span class="group relative inline-flex items-center">
    <button
      type="button"
      aria-label="What is npm?"
      class={`inline-flex cursor-help rounded-full transition-colors ${iconColor} focus:outline-none focus-visible:ring-2 focus-visible:ring-orange`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M12 16v-4"></path>
        <path d="M12 8h.01"></path>
      </svg>
    </button>
    <span
      role="tooltip"
      class="pointer-events-none absolute bottom-full left-1/2 z-20 mb-2.5 w-64 -translate-x-1/2 rounded-lg border border-white/10 bg-[#0f1424] px-3.5 py-2.5 text-left font-body text-[0.8rem] font-light leading-snug text-white/90 opacity-0 shadow-xl transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100"
    >
      npm is JavaScript's standard package manager — it installs code libraries.
      Your AI coding agent runs this command to add Hayao to a project.
      <span
        class="absolute left-1/2 top-full h-2.5 w-2.5 -translate-x-1/2 -translate-y-[6px] rotate-45 border-b border-r border-white/10 bg-[#0f1424]"
      ></span>
    </span>
  </span>
</span>
