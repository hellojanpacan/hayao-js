---
import Logo from "./Logo.astro";
const nav = [
  { label: "Play", href: "/play" },
  { label: "Create", href: "/create" },
  { label: "Docs", href: "/docs" },
];
---
<header class="border-b border-hair">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- brand: icon cap-aligned to the wordmark -->
    <a
      href="/"
      class="flex items-baseline gap-2 font-display text-[1.375rem] font-semibold text-ink no-underline"
    >
      <Logo class="h-[1cap] w-[1cap]" />
      <span>Hayao<span class="text-muted">.js</span></span>
    </a>

    <nav class="flex items-center gap-6">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="font-body text-[0.95rem] font-normal text-ink no-underline transition-colors hover:text-orange"
          >
            {item.label}
          </a>
        ))
      }
      <span class="h-5 w-px bg-hair" aria-hidden="true"></span>
      <a
        href="https://github.com/hellojanpacan/hayao-js"
        aria-label="GitHub"
        class="flex text-ink transition-colors hover:text-orange"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
    </nav>
  </div>
</header>
