---
/**
 * The Claude Code plugin callout — a slim companion to AgentPrompt shown on
 * every /create page. Any agent can build a Hayao game from the pasted prompt;
 * Claude Code users additionally get the packaged skills, commands and the
 * hook-enforced determinism gate by installing the plugin.
 */
interface Props {
  /** Extra classes on the wrapper (spacing is the caller's job). */
  class?: string;
}
const { class: className = "" } = Astro.props;

const install = "/plugin marketplace add hellojanpacan/hayao-js\n/plugin install hayao@hayao";
---

<div class:list={["plugin-callout mx-auto w-full max-w-2xl rounded-3xl border border-hair bg-panel p-6 text-left md:p-8", className]}>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="font-body text-[0.72rem] uppercase tracking-[0.16em] text-orange">Using Claude Code?</p>
      <h3 class="mt-2 font-display text-[1.1rem] font-semibold text-ink">Install the Hayao plugin</h3>
      <p class="mt-1 font-body text-[0.85rem] font-light leading-relaxed text-soft">
        The workflow above, packaged and <em>enforced</em>: authoring skills, commands like{" "}
        <code class="rounded bg-ink/5 px-1 py-0.5 font-mono text-[0.78rem]">/hayao:new-game</code>{" "}
        and <code class="rounded bg-ink/5 px-1 py-0.5 font-mono text-[0.78rem]">/hayao:inspect-api</code>,
        and a determinism gate — a hook that runs the proof harness and blocks the agent from
        finishing until it passes. Verification stops being a habit and becomes a wall.
      </p>
    </div>
    <button
      type="button"
      class="copy-btn inline-flex shrink-0 items-center gap-2 rounded-full border border-hair bg-transparent px-4 py-2 font-body text-[0.85rem] font-semibold text-ink transition-colors hover:border-orange/50 hover:text-orange focus:outline-none focus-visible:ring-2 focus-visible:ring-orange"
      aria-label="Copy plugin install commands"
    >
      <svg class="ico-copy" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>
      <svg class="ico-check" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
      <span class="copy-label">Copy</span>
    </button>
  </div>
  <pre class="install-text mt-4 overflow-auto whitespace-pre rounded-xl border border-[#303a63] bg-[#141a30] p-4 font-mono text-[0.78rem] leading-relaxed text-[#eef1f9]">{install}</pre>
</div>

<style>
  .ico-check {
    display: none;
  }
  .copy-btn.copied .ico-copy {
    display: none;
  }
  .copy-btn.copied .ico-check {
    display: block;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".plugin-callout .copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.closest(".plugin-callout")?.querySelector(".install-text")?.textContent ?? "";
      let ok = false;
      try {
        await navigator.clipboard.writeText(text);
        ok = true;
      } catch {
        try {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          ok = document.execCommand("copy");
          ta.remove();
        } catch {
          /* clipboard unavailable */
        }
      }
      if (ok) {
        btn.classList.add("copied");
        const label = btn.querySelector(".copy-label");
        if (label) label.textContent = "Copied";
        setTimeout(() => {
          btn.classList.remove("copied");
          if (label) label.textContent = "Copy";
        }, 1600);
      }
    });
  });
</script>
