---
import Layout from "../layouts/Layout.astro";
import { LOGO_VIEWBOX, LOGO_CROWN, LOGO_RULE, LOCKUP_VIEWBOX, WORDMARK_HAYAO, WORDMARK_JS } from "../components/logo";
---

<Layout
  title="Style — Hayao.js"
  description="The Hayao.js Bold Duotone vector style — palette, icons, drawings, marks, game assets and UI, all in the Regalia palette."
>
<div class="page">
  <div class="wrap">

    <!-- ══ HERO ══ -->
    <header class="hero">
      <div class="hero-grid">
        <div>
          <p class="eyebrow">Hayao.js &middot; vector style guide</p>
          <h1>Bold, <span class="tint">friendly,</span><br>one hue at two weights.</h1>
          <p class="lede">A moodboard for the house style: rounded, comic-clean shapes
            in the Solar&nbsp;Bold&nbsp;Duotone manner &mdash; a soft mass at 32% opacity, a
            crisp focal shape at full &mdash; coloured only from the Hayao palette. Icons,
            drawings, marks, game assets and UI, all cut from the same cloth.</p>
          <div class="credit">
            <svg viewBox={LOGO_VIEWBOX} aria-hidden="true"><path d={LOGO_CROWN} fill="var(--orange)"/><path d={LOGO_RULE} fill="var(--ink)"/></svg>
            <span>Origin: the Regalia crown from&#32;<a href="https://www.streamlinehq.com/icons/solar-bold-duotone">Solar Bold Duotone</a>, recut in Hayao colours.</span>
          </div>
        </div>

        <div class="stage" aria-label="Anatomy of the mark">
          <div class="stage-grid"></div>
          <svg class="mark" viewBox="1 1 22 22" aria-hidden="true"><path d={LOGO_CROWN} fill="var(--orange)"/><path d={LOGO_RULE} fill="var(--ink)"/></svg>
          <span class="anno a1">mass &middot; <b>#e59500</b> @ 100%</span>
          <span class="anno a2">rule &middot; <b>#29335c</b></span>
        </div>
      </div>
    </header>

    <hr class="rule">

    <!-- ══ PALETTE ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">01 &middot; Palette</p>
          <h2>A core of four, grown by the job</h2>
        </div>
        <p class="lede">Every shape is a single hue shown at two opacities &mdash; the left
          half full, the right half at 32%. That pairing is the whole trick.</p>
      </div>
      <div class="swatches">
        <div class="sw"><div class="sw-duo" style="background:var(--orange)"><div class="full"></div><div class="part" style="background:var(--orange)"></div></div>
          <div class="sw-body"><div class="name">Regalia Gold</div><div class="hex">#e59500</div><div class="role">Primary &middot; marks, CTAs, joy</div></div></div>
        <div class="sw"><div class="sw-duo" style="background:var(--navy)"><div class="full"></div><div class="part" style="background:var(--navy)"></div></div>
          <div class="sw-body"><div class="name">Ink Navy</div><div class="hex">#29335c</div><div class="role">Structure &middot; rules, type, line</div></div></div>
        <div class="sw"><div class="sw-duo" style="background:var(--green)"><div class="full"></div><div class="part" style="background:var(--green)"></div></div>
          <div class="sw-body"><div class="name">Meadow</div><div class="hex">#337357</div><div class="role">Growth &middot; nature, success</div></div></div>
        <div class="sw"><div class="sw-duo" style="background:var(--blue)"><div class="full"></div><div class="part" style="background:var(--blue)"></div></div>
          <div class="sw-body"><div class="name">Dusk Blue</div><div class="hex">#669bbc</div><div class="role">Calm &middot; sky, water, tech</div></div></div>
      </div>

      <div class="pal-ext">
        <div class="pal-ext-copy">
          <p class="eyebrow">Extended &middot; purpose-scoped</p>
          <p class="lede">Grow the palette by the job, not the mood. A new hue earns its
            place only by owning one specific thing &mdash; and it stays out of the core
            UI chrome, which the four above keep to themselves.</p>
        </div>
        <div class="ext-sw">
          <div class="sw rose"><div class="sw-duo" style="background:var(--rose)"><div class="full"></div><div class="part" style="background:var(--rose)"></div></div>
            <div class="sw-body"><div class="job">Vitality</div><div class="name">Rose</div><div class="hex">#c65b5b</div><div class="role">Hearts, health, damage &mdash; nothing else reads right in gold or green</div></div></div>
          <div class="sw bark"><div class="sw-duo" style="background:var(--bark)"><div class="full"></div><div class="part" style="background:var(--bark)"></div></div>
            <div class="sw-body"><div class="job">Material</div><div class="name">Bark</div><div class="hex">#7a4f34</div><div class="role">Wood &amp; earth &mdash; trunks, crates, soil, roots</div></div></div>
        </div>
      </div>
    </section>

    <hr class="rule">

    <!-- ══ ICONS ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">02 &middot; Icons</p>
          <h2>A duotone icon set</h2>
        </div>
        <p class="lede">24-grid, no outlines. Broad backdrop at 32%, the focal detail
          at 100%, all of one hue. Hover to feel the lift.</p>
      </div>
      <div class="icons"><div class="icon" style="animation-delay:0ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--orange)" aria-label="Regalia icon"><path d={LOGO_CROWN} fill="var(--orange)"/><path d={LOGO_RULE} fill="var(--ink)"/></svg><span>Regalia</span></div><div class="icon" style="animation-delay:35ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--blue)" aria-label="Play icon"><path class="duo-mass" d="M8 6h8a6 6 0 0 1 5.9 5l.5 3.5A3.2 3.2 0 0 1 19.3 18a3.4 3.4 0 0 1-2.8-1.5L15.4 15H8.6l-1.1 1.5A3.4 3.4 0 0 1 4.7 18 3.2 3.2 0 0 1 1.6 14.5L2.1 11A6 6 0 0 1 8 6Z"/><rect x="5" y="10.6" width="5" height="1.8" rx=".9"/><rect x="6.6" y="9" width="1.8" height="5" rx=".9"/><circle cx="16" cy="10.6" r="1.15"/><circle cx="18.1" cy="12.7" r="1.15"/></svg><span>Play</span></div><div class="icon" style="animation-delay:70ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--orange)" aria-label="Star icon"><path class="duo-mass" d="M12 2.6c.5 0 .9.3 1.13.75l2.36 4.78 5.28.77c1 .15 1.4 1.38.68 2.08l-3.82 3.72.9 5.26c.17 1-.88 1.76-1.78 1.29L12 18.9l-4.72 2.48c-.9.47-1.95-.3-1.78-1.29l.9-5.26-3.82-3.72c-.72-.7-.32-1.93.68-2.08l5.28-.77 2.36-4.78c.23-.45.63-.75 1.13-.75Z"/><path d="M12 8.5l1.1 2.4 2.4 1.1-2.4 1.1L12 15.5l-1.1-2.4L8.5 12l2.4-1.1z"/></svg><span>Star</span></div><div class="icon" style="animation-delay:105ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--rose)" aria-label="Heart icon"><path class="duo-mass" d="M12 20.7l-1.1-1C6.14 15.28 3 12.42 3 8.9 3 6.2 5.1 4.1 7.8 4.1c1.54 0 3.02.72 3.98 1.87A5.2 5.2 0 0 1 16.2 4.1C18.9 4.1 21 6.2 21 8.9c0 3.52-3.14 6.38-7.9 10.8z"/><path d="M8.7 7c-1.05 0-1.98.68-2.3 1.7a.8.8 0 0 0 1.52.48c.12-.4.42-.66.78-.66a.8.8 0 0 0 0-1.52z"/></svg><span>Heart</span></div><div class="icon" style="animation-delay:140ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--green)" aria-label="Puzzle icon"><path class="duo-mass" d="M13.5 3a1.5 1.5 0 0 0-3 0c0 .4.16.76.2 1-.05.5-.45.8-.9.8H7.5A1.5 1.5 0 0 0 6 6.3v2.3c0 .45-.3.85-.8.9-.24-.04-.6-.2-1-.2a1.5 1.5 0 0 0 0 3c.4 0 .76-.16 1-.2.5.05.8.45.8.9v2.6c0 .83.67 1.5 1.5 1.5h2.6c.45 0 .85.3.9.8-.04.24-.2.6-.2 1a1.5 1.5 0 0 0 3 0c0-.4-.16-.76-.2-1 .05-.5.45-.8.9-.8h2.3a1.5 1.5 0 0 0 1.5-1.5v-2.8c0-.45.3-.85.8-.9.24.04.6.2 1 .2a1.5 1.5 0 0 0 0-3c-.4 0-.76.16-1 .2-.5-.05-.8-.45-.8-.9V6.3a1.5 1.5 0 0 0-1.5-1.5h-2.3c-.45 0-.85-.3-.9-.8.04-.24.2-.6.2-1Z"/><circle cx="12" cy="11.6" r="2.1"/></svg><span>Puzzle</span></div><div class="icon" style="animation-delay:175ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--navy)" aria-label="Sword icon"><path class="duo-mass" d="M11 3a1 1 0 0 1 2 0v11.5h-2z"/><rect x="7.4" y="14.3" width="9.2" height="2.3" rx="1.15"/><rect x="11" y="16.6" width="2" height="3.8" rx="1"/><circle cx="12" cy="21" r="1.5"/></svg><span>Sword</span></div><div class="icon" style="animation-delay:210ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--blue)" aria-label="Shield icon"><path class="duo-mass" d="M12 2.3l7 2.4c.6.2 1 .77 1 1.4v5.1c0 4.2-2.7 7.1-7.6 9.3a1 1 0 0 1-.8 0C6.7 18.3 4 15.4 4 11.2V6.1c0-.63.4-1.2 1-1.4l7-2.4z"/><path d="M10.7 15.2a1 1 0 0 1-.72-.3l-1.95-1.95a1 1 0 0 1 1.42-1.42l1.23 1.24 3.15-3.5a1 1 0 1 1 1.48 1.34l-3.86 4.28a1 1 0 0 1-.73.33z"/></svg><span>Shield</span></div><div class="icon" style="animation-delay:245ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--orange)" aria-label="Coin icon"><circle class="duo-mass" cx="12" cy="12" r="9"/><path d="M12 7.2l1.42 3.03 3.33.38-2.47 2.25.66 3.28L12 14.6l-2.94 1.62.66-3.28-2.47-2.25 3.33-.38z"/></svg><span>Coin</span></div><div class="icon" style="animation-delay:280ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--blue)" aria-label="Gem icon"><path class="duo-mass" d="M8.4 4 15.6 4 Q17 4 17.74 5.2 L20.26 9.3 Q21 10.5 20.09 11.57 L13.04 19.78 Q12 21 10.96 19.78 L4.04 11.72 Q3 10.5 3.74 9.3 L6.26 5.2 Q7 4 8.4 4 Z"/><path d="M8.4 4 15.6 4 Q17 4 17.74 5.2 L18.7 8 5.3 8 6.26 5.2 Q7 4 8.4 4 Z"/></svg><span>Gem</span></div><div class="icon" style="animation-delay:315ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--green)" aria-label="Rocket icon"><path class="duo-mass" d="M12 2c2.6 2.1 3.9 5.1 3.9 8.6v3.1H8.1v-3.1C8.1 7.1 9.4 4.1 12 2z"/><path class="duo-mass" d="M8.1 11.4L5.4 13.9v3l2.7-1.6zM15.9 11.4L18.6 13.9v3l-2.7-1.6z"/><circle cx="12" cy="8.1" r="1.7"/><path d="M10.3 15.4h3.4c0 2.1-1.05 4-1.7 4.8-.65-.8-1.7-2.7-1.7-4.8z"/></svg><span>Rocket</span></div><div class="icon" style="animation-delay:350ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--orange)" aria-label="Key icon"><circle class="duo-mass" cx="12" cy="7" r="4.6"/><rect x="10.9" y="10.6" width="2.2" height="9.9" rx="1.1"/><rect x="12.9" y="14.8" width="3" height="2" rx="1"/><rect x="12.9" y="17.8" width="2.4" height="2" rx="1"/><circle cx="12" cy="7" r="1.7"/></svg><span>Key</span></div><div class="icon" style="animation-delay:385ms"><svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--orange)" aria-label="Magic icon"><path class="duo-mass" d="M12 2c.4 0 .75.26.88.64l1.5 4.48c.2.6.68 1.08 1.28 1.28l4.48 1.5a.93.93 0 0 1 0 1.76l-4.48 1.5c-.6.2-1.08.68-1.28 1.28l-1.5 4.48a.93.93 0 0 1-1.76 0l-1.5-4.48c-.2-.6-.68-1.08-1.28-1.28l-4.48-1.5a.93.93 0 0 1 0-1.76l4.48-1.5c.6-.2 1.08-.68 1.28-1.28l1.5-4.48A.93.93 0 0 1 12 2z"/><path d="M19 2.6l.6 1.6 1.6.6-1.6.6L19 7l-.6-1.6-1.6-.6 1.6-.6z"/><path d="M5 14.5l.55 1.45 1.45.55-1.45.55L5 18.5l-.55-1.45L3 16.5l1.45-.55z"/></svg><span>Magic</span></div></div>
    </section>

    <hr class="rule">

    <!-- ══ DRAWINGS ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">03 &middot; Drawings</p>
          <h2>Scenes from the same recipe</h2>
        </div>
        <p class="lede">Bigger illustrations are just stacked duotone masses &mdash; flat,
          rounded, layered light-to-dark. No gradients, no outlines.</p>
      </div>
      <div class="scenes"><div class="scene"><svg viewBox="0 0 320 190"><circle class="duo-mass" cx="248" cy="58" r="46" fill="var(--orange)"/><circle cx="248" cy="58" r="30" fill="var(--orange)"/><g fill="var(--blue)" class="duo-mass"><circle cx="70" cy="52" r="17"/><circle cx="92" cy="52" r="21"/><circle cx="116" cy="54" r="16"/><rect x="70" y="52" width="46" height="18"/></g><path class="duo-mass" fill="var(--green)" d="M0 132 Q80 92 175 122 T320 108 V190 H0 Z"/><path fill="var(--green)" d="M0 158 Q95 124 185 150 T320 146 V190 H0 Z"/><rect x="243" y="149" width="6" height="24" rx="3" fill="var(--bark)"/><circle class="duo-mass" cx="246" cy="143" r="17" fill="var(--green)"/><circle cx="246" cy="146" r="13" fill="var(--green)"/></svg><div class="cap"><div class="t">Golden hour</div><div class="d">Sun &middot; hills &middot; a drifting cloud</div></div></div><div class="scene"><svg viewBox="0 0 320 190"><path class="duo-mass" fill="var(--green)" d="M0 150 Q160 128 320 150 V190 H0 Z"/><circle cx="96" cy="150" r="12" fill="var(--orange)"/><circle cx="222" cy="152" r="11" fill="var(--orange)"/><circle cx="120" cy="160" r="9" fill="var(--orange)"/><rect x="108" y="96" width="104" height="62" rx="12" fill="var(--orange)"/><path class="duo-mass" fill="var(--orange)" d="M108 100a52 30 0 0 1 104 0v6H108z"/><rect x="150" y="96" width="20" height="62" fill="var(--navy)"/><rect x="152" y="120" width="16" height="18" rx="4" fill="var(--navy)"/><path fill="var(--blue)" d="M255 60l2.4 6.4 6.4 2.4-6.4 2.4L255 78l-2.4-6.4-6.4-2.4 6.4-2.4z"/><path class="duo-mass" fill="var(--blue)" d="M70 74l1.6 4 4 1.6-4 1.6L70 86l-1.6-4-4-1.6 4-1.6z"/></svg><div class="cap"><div class="t">Buried treasure</div><div class="d">A chest, spilling coins</div></div></div><div class="scene"><svg viewBox="0 0 320 190"><rect class="duo-mass" width="320" height="190" fill="var(--navy)"/><circle cx="66" cy="56" r="30" fill="var(--blue)"/><circle class="duo-mass" cx="78" cy="50" r="26" fill="var(--navy)"/><g fill="var(--orange)"><path d="M210 40l1.8 4.8 4.8 1.8-4.8 1.8L210 53l-1.8-4.8-4.8-1.8 4.8-1.8z"/><path d="M258 78l1.4 3.7 3.7 1.4-3.7 1.4L258 88l-1.4-3.7-3.7-1.4 3.7-1.4z"/><circle cx="150" cy="34" r="2.4"/><circle cx="286" cy="40" r="2"/><circle cx="120" cy="72" r="1.8"/></g><g fill="var(--navy)"><path d="M150 78h140v10H150z"/><path d="M156 92h128v7H156z"/><rect x="176" y="88" width="12" height="82" rx="2"/><rect x="252" y="88" width="12" height="82" rx="2"/></g><rect y="168" width="320" height="22" fill="var(--navy)"/></svg><div class="cap"><div class="t">Night gate</div><div class="d">Moon, stars & a lone torii</div></div></div></div>
    </section>

    <hr class="rule">

    <!-- ══ LOGOS ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">04 &middot; Marks &amp; lockups</p>
          <h2>The crown, wearing different clothes</h2>
        </div>
        <p class="lede">One silhouette, flexible dress: gold-on-paper, reversed,
          knocked into a badge, or mono for a single-colour print.</p>
      </div>
      <div class="logos"><div class="logo"><div class="lockup"><svg viewBox={LOCKUP_VIEWBOX} role="img" aria-label="Hayao.js"><path d={LOGO_CROWN} fill="var(--orange)"/><path d={LOGO_RULE} fill="var(--ink)"/><path d={WORDMARK_HAYAO} fill="var(--ink)"/><path d={WORDMARK_JS} fill="var(--muted)"/></svg></div><span class="tag">Primary lockup</span></div><div class="logo"><div class="badge"><svg viewBox={LOGO_VIEWBOX} aria-hidden="true"><path d={LOGO_CROWN} fill="#fff"/><path d={LOGO_RULE} fill="#fff"/></svg></div><span class="tag">App badge</span></div><div class="logo dark"><div class="lockup"><svg viewBox={LOCKUP_VIEWBOX} role="img" aria-label="Hayao.js"><path d={LOGO_CROWN} fill="var(--orange)"/><path d={LOGO_RULE} fill="#fff"/><path d={WORDMARK_HAYAO} fill="#fff"/><path d={WORDMARK_JS} fill="#9aa6d0"/></svg></div><span class="tag">Reverse</span></div><div class="logo"><div style="width:52px"><svg viewBox={LOGO_VIEWBOX} aria-hidden="true"><path d={LOGO_CROWN} fill="var(--ink)"/><path d={LOGO_RULE} fill="var(--ink)"/></svg></div><span class="tag">Monochrome</span></div></div>
    </section>

    <hr class="rule">

    <!-- ══ GAME ASSETS ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">05 &middot; Game assets</p>
          <h2>Sprites &amp; pickups</h2>
        </div>
        <p class="lede">The style is built for play &mdash; a friendly cast and a shelf of
          collectibles that read at 16px or 64px.</p>
      </div>
      <div class="assets-stage">
        <div class="assets"><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Hero"><path fill="var(--green)" d="M4 15c0-4.4 3.6-8 8-8s8 3.6 8 8v1.4c0 .8-.65 1.5-1.45 1.5-.6 0-1.1-.35-1.38-.86-.28.5-.8.86-1.4.86s-1.12-.36-1.4-.86c-.28.5-.8.86-1.4.86h-.16c-.6 0-1.12-.36-1.4-.86-.28.5-.8.86-1.4.86s-1.12-.36-1.4-.86c-.28.5-.78.86-1.38.86C4.65 17.9 4 17.2 4 16.4z"/><ellipse class="duo-mass" cx="12" cy="13.4" rx="5" ry="3.4" fill="var(--green)"/><circle cx="9.6" cy="12" r="1.15" fill="var(--navy)"/><circle cx="14.4" cy="12" r="1.15" fill="var(--navy)"/><path d="M10.4 14.3c.55.55 2.65.55 3.2 0" fill="none" stroke="var(--navy)" stroke-width="1.1" stroke-linecap="round"/></svg></div><span>Hero</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Coin"><circle cx="12" cy="12" r="9" fill="var(--orange)"/><circle class="duo-mass" cx="12" cy="12" r="6.4" fill="var(--orange)"/><path fill="var(--orange)" d="M12 8.2l1.15 2.45 2.7.3-2 1.82.53 2.66L12 14.4l-2.38 1.32.53-2.66-2-1.82 2.7-.3z"/><path fill="#fff" class="duo-mass" d="M8.2 6.6l.4 1 1 .4-1 .4-.4 1-.4-1-1-.4 1-.4z"/></svg></div><span>Coin</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Life"><path fill="var(--rose)" d="M12 20.7l-1.1-1C6.14 15.28 3 12.42 3 8.9 3 6.2 5.1 4.1 7.8 4.1c1.54 0 3.02.72 3.98 1.87A5.2 5.2 0 0 1 16.2 4.1C18.9 4.1 21 6.2 21 8.9c0 3.52-3.14 6.38-7.9 10.8z"/><path class="duo-mass" fill="#fff" d="M8.6 6.6c-1.1 0-2.05.72-2.36 1.78a.78.78 0 0 0 1.5.44c.12-.42.44-.7.86-.7a.78.78 0 0 0 0-1.52z"/></svg></div><span>Life</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Gem"><path class="duo-mass" fill="var(--blue)" d="M8.4 4 15.6 4 Q17 4 17.74 5.2 L20.26 9.3 Q21 10.5 20.09 11.57 L13.04 19.78 Q12 21 10.96 19.78 L4.04 11.72 Q3 10.5 3.74 9.3 L6.26 5.2 Q7 4 8.4 4 Z"/><path fill="var(--blue)" d="M8.4 4 15.6 4 Q17 4 17.74 5.2 L18.7 8 5.3 8 6.26 5.2 Q7 4 8.4 4 Z"/><ellipse cx="8.9" cy="6.5" rx="1.6" ry=".72" transform="rotate(-30 8.9 6.5)" fill="#fff" opacity=".42"/></svg></div><span>Gem</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Key"><circle class="duo-mass" cx="12" cy="7" r="4.6" fill="var(--orange)"/><rect x="10.9" y="10.6" width="2.2" height="9.9" rx="1.1" fill="var(--orange)"/><rect x="12.9" y="14.8" width="3" height="2" rx="1" fill="var(--orange)"/><rect x="12.9" y="17.8" width="2.4" height="2" rx="1" fill="var(--orange)"/><circle cx="12" cy="7" r="1.7" fill="var(--orange)"/></svg></div><span>Key</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Ground"><rect class="duo-mass" x="3" y="8" width="18" height="13" rx="3" fill="var(--green)"/><path fill="var(--green)" d="M3 11a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v1.2c-1.1 0-1.3 1.1-2.6 1.1S16.9 12 15.6 12s-1.3 1.3-2.6 1.3S11.7 12 10.4 12 9.1 13.3 7.8 13.3 6.5 12 5.2 12 3.9 12.3 3 12.4z"/><circle cx="8" cy="17" r="1" fill="var(--navy)" opacity=".45"/><circle cx="15" cy="18.4" r="1" fill="var(--navy)" opacity=".45"/></svg></div><span>Ground</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Hazard"><rect class="duo-mass" x="3" y="18.5" width="18" height="2.5" rx="1.2" fill="var(--navy)"/><path fill="var(--navy)" d="M4 19l2.7-9 2.7 9zM9.3 19l2.7-9 2.7 9zM14.6 19l2.7-9 2.7 9z"/></svg></div><span>Hazard</span></div><div class="asset"><div class="pod"><svg viewBox="0 0 24 24" aria-label="Goal"><rect class="duo-mass" x="6" y="3" width="1.9" height="18" rx=".95" fill="var(--navy)"/><path fill="var(--orange)" d="M7.9 4h9.6c.55 0 .82.66.44 1.06L15.2 8l2.74 2.94c.38.4.11 1.06-.44 1.06H7.9z"/></svg></div><span>Goal</span></div></div>
      </div>
    </section>

    <hr class="rule">

    <!-- ══ COMPONENTS ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">06 &middot; Components</p>
          <h2>UI cut from the same palette</h2>
        </div>
        <p class="lede">Rounded corners, soft coloured shadows, gold reserved for the
          one action that matters most on screen.</p>
      </div>
      <div class="comp-grid">
        <div class="comp">
          <h3>Buttons &amp; badges</h3>
          <div class="row" style="margin-bottom:18px">
            <button class="btn btn-primary"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.7 5.2c.2.6.5.9 1.1 1.1L20 10l-5.2 1.7c-.6.2-.9.5-1.1 1.1L12 18l-1.7-5.2c-.2-.6-.5-.9-1.1-1.1L4 10l5.2-1.7c.6-.2.9-.5 1.1-1.1z"/></svg> Get Started</button>
            <button class="btn btn-ghost"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 5A1.5 1.5 0 0 1 5.5 3.5H11v17H5.5A1.5 1.5 0 0 1 4 19zM13 3.5h5.5A1.5 1.5 0 0 1 20 5v14a1.5 1.5 0 0 1-1.5 1.5H13z"/></svg> Read the docs</button>
          </div>
          <div class="row" style="margin-bottom:22px">
            <span class="pill pill-green"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.5 16.3a1 1 0 0 1-.72-.3l-3.5-3.5a1 1 0 1 1 1.44-1.4l2.78 2.8 6.8-6.8a1 1 0 1 1 1.4 1.42l-7.5 7.48a1 1 0 0 1-.7.3z"/></svg> Solver-proven</span>
            <span class="pill pill-orange"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.4 4.9 5.4.8-3.9 3.8.9 5.4L12 15.4 7.2 17.9l.9-5.4L4.2 8.7l5.4-.8z"/></svg> Featured</span>
            <span class="pill pill-blue"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L4 13.2h6L9 22l9-11.2h-6z"/></svg> Deterministic</span>
          </div>
          <div class="row" style="justify-content:space-between">
            <div class="row"><span class="toggle" aria-hidden="true"></span><span style="font-size:.86rem;color:var(--soft)">Sound on</span></div>
            <div class="row"><span class="toggle off" aria-hidden="true"></span><span style="font-size:.86rem;color:var(--soft)">Reduced motion</span></div>
          </div>
        </div>

        <div class="comp">
          <h3>Cards &amp; state</h3>
          <div class="tile-card" style="margin-bottom:14px">
            <span class="ic" style="color:var(--blue)"><svg viewBox="0 0 24 24" fill="currentColor"><path class="duo-mass" d="M8 6h8a6 6 0 0 1 5.9 5l.5 3.5A3.2 3.2 0 0 1 19.3 18a3.4 3.4 0 0 1-2.8-1.5L15.4 15H8.6l-1.1 1.5A3.4 3.4 0 0 1 4.7 18 3.2 3.2 0 0 1 1.6 14.5L2.1 11A6 6 0 0 1 8 6Z"/><rect x="5" y="10.6" width="5" height="1.8" rx=".9"/><rect x="6.6" y="9" width="1.8" height="5" rx=".9"/><circle cx="16" cy="10.6" r="1.15"/><circle cx="18.1" cy="12.7" r="1.15"/></svg></span>
            <div><div class="tt">2D Platformer</div><div class="dd">Momentum &middot; coyote-time &middot; tight feel</div></div>
          </div>
          <div style="font-size:.78rem;color:var(--muted);margin-bottom:6px">Level progress</div>
          <div class="prog" style="margin-bottom:16px"><i></i></div>
          <div class="row">
            <span class="avatar">H</span>
            <span class="avatar" style="margin-left:-14px;color:var(--orange);background:color-mix(in srgb,var(--orange) 20%,var(--panel))">J</span>
            <span class="avatar" style="margin-left:-14px;color:var(--blue);background:color-mix(in srgb,var(--blue) 22%,var(--panel))">A</span>
            <span style="font-size:.82rem;color:var(--soft);margin-left:6px">+ 24 playtesters</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule">

    <!-- ══ RECIPE ══ -->
    <section>
      <div class="sec-head">
        <div>
          <p class="eyebrow">07 &middot; The recipe</p>
          <h2>Draw anything in five rules</h2>
        </div>
        <p class="lede">Hand this to a person or an agent &mdash; it reproduces the look
          without seeing the corpus.</p>
      </div>
      <div class="recipe">
        <div class="rule-card"><div class="n">RULE 01</div><h3>One hue, two opacities</h3><p>Pick a single palette colour. Everything in the graphic is that colour &mdash; the difference is 100% vs 32% opacity. Never mix two hues inside one icon (the crown&rsquo;s navy rule is the one sanctioned exception).</p></div>
        <div class="rule-card"><div class="n">RULE 02</div><h3>Mass at 32%, focal at 100%</h3><p>The big silhouette is the light layer. The one detail you want the eye to land on &mdash; a face, a keyhole, a star point &mdash; sits on top at full strength.</p></div>
        <div class="rule-card"><div class="n">RULE 03</div><h3>Bold &amp; rounded, no outlines</h3><p>Solid fills only. Generous corner radii, thick limbs, no hairline strokes. If it could survive being shrunk to a 16px favicon, it&rsquo;s bold enough.</p></div>
        <div class="rule-card"><div class="n">RULE 04</div><h3>Friendly geometry</h3><p>Circles over corners, smiles over frowns, a little bounce in the proportions. Comic-clean, never sharp or corporate. Leave air around the subject.</p></div>
        <div class="rule-card"><div class="n">RULE 05</div><h3>24-grid, then scale</h3><p>Author on a 24&times;24 grid so weight stays consistent across the set. Keep it vector &mdash; one path family reads crisp from sprite to billboard.</p></div>
        <div class="rule-card" style="background:var(--navy);border-color:transparent">
          <div class="n" style="color:var(--orange)">DON&rsquo;T</div>
          <h3 style="color:#fff">Break the spell</h3>
          <p style="color:#aeb8db">No gradients, no drop-shadows inside the art, no three-plus colours per shape, no thin outlines, no photographic texture. The charm is in the restraint.</p></div>
      </div>
    </section>

    <footer>
      <b>Hayao.js</b> vector house style &middot; Solar Bold Duotone, recut in the Regalia palette &middot;
      Overpass + Poppins &middot; light &amp; dark aware
    </footer>
  </div>
</div>

</Layout>

<style>
.page{--orange:var(--color-orange);--navy:var(--color-navy);--green:var(--color-green);--blue:var(--color-blue);--rose:var(--color-rose);--bark:var(--color-bark);--ink:var(--color-ink);--soft:var(--color-soft);--muted:var(--color-muted);--hair:var(--color-hair);--panel:var(--color-panel);--panel-2:var(--color-mist);--sh:41 51 92;--disp:var(--font-display);--body:var(--font-body);background:transparent!important;background-image:none!important}
*{box-sizing:border-box}
  body{margin:0}
  .page{
    font-family:var(--body);font-weight:300;color:var(--ink);
    background:var(--ground);
    background-image:radial-gradient(circle at 1px 1px,rgb(var(--sh)/.05) 1px,transparent 0);
    background-size:22px 22px;
    line-height:1.55;-webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:1120px;margin:0 auto;padding:0 24px}
  h1,h2,h3{font-family:var(--disp);font-weight:600;text-wrap:balance;margin:0}
  .eyebrow{font-family:var(--body);font-weight:600;text-transform:uppercase;
    letter-spacing:.18em;font-size:.72rem;color:var(--orange)}
  .lede{color:var(--soft);font-weight:300}

  /* ── Hero ── */
  .hero{padding:76px 0 26px}
  .hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:48px;align-items:center}
  .hero h1{font-size:clamp(2.5rem,5.4vw,4rem);line-height:1.02;letter-spacing:-.02em}
  .hero h1 .tint{color:var(--orange)}
  .hero .lede{font-size:1.12rem;max-width:44ch;margin-top:20px}
  .credit{margin-top:26px;display:inline-flex;gap:10px;align-items:center;
    font-size:.86rem;color:var(--muted);background:var(--panel);
    border:1px solid var(--hair);border-radius:999px;padding:7px 15px 7px 10px}
  .credit svg{width:20px;height:20px;display:block}
  .credit a{color:var(--soft);text-decoration:none;border-bottom:1px solid var(--hair)}

  /* the anatomy stage */
  .stage{position:relative;background:var(--panel);border:1px solid var(--hair);
    border-radius:28px;padding:30px;box-shadow:0 30px 60px -34px rgb(var(--sh)/.5)}
  .stage-grid{position:absolute;inset:30px;border-radius:16px;
    background-image:linear-gradient(rgb(var(--sh)/.06) 1px,transparent 0),
      linear-gradient(90deg,rgb(var(--sh)/.06) 1px,transparent 0);
    background-size:calc(100%/8) calc(100%/8);pointer-events:none}
  .stage .mark{position:relative;display:block;width:100%;height:auto;
    filter:drop-shadow(0 14px 22px rgb(229 149 0 / .28))}
  .anno{position:absolute;font-family:var(--body);font-size:.72rem;font-weight:600;
    color:var(--soft);background:var(--panel-2);border:1px solid var(--hair);
    border-radius:8px;padding:3px 9px;white-space:nowrap;box-shadow:0 4px 10px -4px rgb(var(--sh)/.4)}
  .anno.a1{top:14px;left:14px}
  .anno.a2{bottom:14px;right:14px}
  .anno b{color:var(--orange)}
  .anno.a2 b{color:var(--ink)}

  /* ── Section frame ── */
  section{padding:44px 0}
  .sec-head{display:flex;align-items:baseline;justify-content:space-between;
    gap:20px;margin-bottom:26px;flex-wrap:wrap}
  .sec-head h2{font-size:1.7rem;letter-spacing:-.01em}
  .sec-head .lede{font-size:.95rem;max-width:52ch}
  .rule{height:1px;background:var(--hair);border:0;margin:0}

  /* ── Palette ── */
  .swatches{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
  .sw{background:var(--panel);border:1px solid var(--hair);border-radius:18px;
    overflow:hidden;transition:transform .18s ease,box-shadow .18s ease}
  .sw:hover{transform:translateY(-4px);box-shadow:0 18px 34px -20px rgb(var(--sh)/.5)}
  .sw-duo{height:88px;display:flex}
  .sw-duo .full{flex:1}.sw-duo .part{flex:1;opacity:.32}
  .sw-body{padding:12px 14px 14px}
  .sw-body .name{font-family:var(--disp);font-weight:600;font-size:.98rem}
  .sw-body .hex{font-size:.78rem;color:var(--muted);
    font-variant-numeric:tabular-nums;text-transform:uppercase}
  .sw-body .role{font-size:.76rem;color:var(--soft);margin-top:4px}
  .pal-ext{margin-top:22px;display:grid;grid-template-columns:.82fr 1.18fr;gap:26px;align-items:center}
  .pal-ext-copy .eyebrow{color:var(--soft)}
  .pal-ext-copy p.lede{font-size:.9rem;margin-top:7px;max-width:34ch}
  .ext-sw{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
  .sw-body .job{display:inline-block;margin-bottom:3px;font-family:var(--body);font-weight:600;
    font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--orange)}
  .sw.rose .job{color:var(--rose)}.sw.bark .job{color:var(--bark)}

  /* ── Icon grid ── */
  .icons{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
  .icon{background:var(--panel);border:1px solid var(--hair);border-radius:18px;
    aspect-ratio:1/1;display:flex;flex-direction:column;align-items:center;
    justify-content:center;gap:10px;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .icon:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--orange) 45%,var(--hair));
    box-shadow:0 18px 30px -20px rgb(var(--sh)/.55)}
  .icon svg{width:46px;height:46px;display:block}
  .icon span{font-size:.72rem;color:var(--muted);font-weight:400}
  .duo-mass{opacity:.32}

  /* ── Drawings ── */
  .scenes{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .scene{background:var(--panel);border:1px solid var(--hair);border-radius:20px;
    overflow:hidden;box-shadow:0 20px 40px -28px rgb(var(--sh)/.5)}
  .scene svg{display:block;width:100%;height:auto}
  .scene .cap{padding:12px 16px 15px}
  .scene .cap .t{font-family:var(--disp);font-weight:600;font-size:.98rem}
  .scene .cap .d{font-size:.78rem;color:var(--muted)}

  /* ── Logos ── */
  .logos{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
  .logo{border-radius:20px;border:1px solid var(--hair);background:var(--panel);
    min-height:150px;display:flex;flex-direction:column;align-items:center;
    justify-content:center;gap:14px;padding:22px;text-align:center}
  .logo.dark{background:var(--navy);border-color:transparent}
  .logo.badge-fill{background:var(--orange);border-color:transparent}
  .logo .tag{font-size:.72rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
  .logo.dark .tag{color:#8290bd}
  /* the canonical lockup is one outlined SVG (see components/logo.ts) — just size it */
  .lockup svg{height:1.4rem;width:auto;display:block}
  .logo .badge{width:66px;height:66px;border-radius:20px;background:var(--orange);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 12px 22px -10px rgb(229 149 0 / .6)}
  .logo .badge svg{width:40px;height:40px}

  /* ── Game assets ── */
  .assets-stage{background:
      linear-gradient(180deg,color-mix(in srgb,var(--blue) 16%,var(--panel)),var(--panel));
    border:1px solid var(--hair);border-radius:22px;padding:26px;
    box-shadow:inset 0 -40px 60px -50px rgb(var(--sh)/.4)}
  .assets{display:grid;grid-template-columns:repeat(8,1fr);gap:14px}
  .asset{display:flex;flex-direction:column;align-items:center;gap:9px}
  .asset .pod{width:100%;aspect-ratio:1/1;background:var(--panel);
    border:1px solid var(--hair);border-radius:16px;display:flex;
    align-items:center;justify-content:center;box-shadow:0 8px 16px -12px rgb(var(--sh)/.5)}
  .asset svg{width:48px;height:48px;display:block}
  .asset span{font-size:.7rem;color:var(--muted)}

  /* ── Components ── */
  .comp-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:18px}
  .comp{background:var(--panel);border:1px solid var(--hair);border-radius:20px;padding:22px}
  .comp h3{font-size:.8rem;text-transform:uppercase;letter-spacing:.14em;
    color:var(--muted);font-family:var(--body);font-weight:600;margin-bottom:16px}
  .row{display:flex;flex-wrap:wrap;gap:12px;align-items:center}
  .btn{font-family:var(--body);font-weight:600;font-size:.9rem;border-radius:12px;
    padding:11px 18px;border:1px solid transparent;cursor:pointer;
    display:inline-flex;align-items:center;gap:8px;transition:filter .15s ease,transform .15s ease}
  .btn:hover{transform:translateY(-2px)}
  .btn svg{width:18px;height:18px}
  .btn-primary{background:var(--orange);color:#fff;box-shadow:0 10px 20px -10px rgb(229 149 0 / .7)}
  .btn-primary:hover{filter:brightness(1.05)}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--hair)}
  .btn-ghost:hover{border-color:var(--orange);color:var(--orange)}
  .pill{display:inline-flex;align-items:center;gap:7px;font-size:.78rem;font-weight:600;
    padding:5px 12px;border-radius:999px}
  .pill svg{width:14px;height:14px}
  .pill-green{background:color-mix(in srgb,var(--green) 16%,transparent);color:var(--green)}
  .pill-orange{background:color-mix(in srgb,var(--orange) 18%,transparent);color:var(--orange)}
  .pill-blue{background:color-mix(in srgb,var(--blue) 20%,transparent);color:var(--blue)}
  .toggle{width:52px;height:30px;border-radius:999px;background:var(--orange);
    position:relative;box-shadow:inset 0 2px 5px rgb(var(--sh)/.35)}
  .toggle::after{content:"";position:absolute;top:3px;left:25px;width:24px;height:24px;
    border-radius:50%;background:#fff;box-shadow:0 3px 6px rgb(var(--sh)/.5)}
  .toggle.off{background:var(--hair)}.toggle.off::after{left:3px}
  .field{display:flex;align-items:center;gap:11px;border:1px solid var(--hair);
    border-radius:12px;padding:10px 14px;background:var(--panel-2);color:var(--muted);font-size:.9rem}
  .field .chip{margin-left:auto;font-size:.72rem;font-weight:600;color:var(--green);
    background:color-mix(in srgb,var(--green) 15%,transparent);padding:3px 9px;border-radius:999px}
  .prog{height:12px;border-radius:999px;background:var(--hair);overflow:hidden}
  .prog i{display:block;height:100%;width:68%;border-radius:999px;
    background:linear-gradient(90deg,var(--orange),color-mix(in srgb,var(--orange) 60%,var(--green)))}
  .tile-card{display:flex;gap:14px;align-items:center;padding:14px;border-radius:16px;
