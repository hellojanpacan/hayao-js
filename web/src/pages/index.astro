---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import InstallBox from "../components/InstallBox.astro";

const benefits = [
  { c: "green", t: "Prove it works", d: "Run in Node, assert on state. No browser, no pixels, no flakiness." },
  { c: "green", t: "Prove it's winnable", d: "step() is a pure transition, so a solver can search every level to the end." },
  { c: "blue", t: "Refactor without fear", d: "Replay the input log, compare the hash. Identical, or it's a regression." },
  { c: "blue", t: "Time-travel & undo", d: "snapshot() and restore() any tick. Undo and save-states fall out for free." },
  { c: "orange", t: "Replays & scrubbing", d: "A whole session is just its input log — jump to any moment and re-simulate." },
  { c: "orange", t: "Rollback multiplayer", d: "Determinism is exactly what makes lockstep and rollback netcode possible." },
];
const dot = { green: "bg-green", blue: "bg-blue", orange: "bg-orange" } as const;
---

<Layout>
  <main class="flex flex-col items-center text-center">
    <!-- ── HERO ── -->
    <section class="mx-auto flex max-w-2xl flex-col items-center px-6 pt-28 pb-24 md:pt-36">
      <h1 class="text-balance font-display text-[clamp(2.5rem,7vw,4.25rem)] font-semibold leading-[1.04] tracking-[-0.015em] text-ink">
        Give your AI Agent<br />a Game Engine
      </h1>
      <p class="mt-6 max-w-[42ch] font-body text-[1.15rem] font-light leading-relaxed text-soft">
        You have the game idea — now your AI can build it. Free &amp; open source.
      </p>
      <div class="mt-10">
        <InstallBox />
      </div>
    </section>

    <!-- ── AI-NATIVE ── -->
    <section class="mx-auto max-w-2xl px-6 py-20 md:py-24">
      <p class="mb-4 font-body text-[0.75rem] uppercase tracking-[0.2em] text-orange">AI-native</p>
      <h2 class="mx-auto max-w-[20ch] text-balance font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-ink">
        Built for the machine that writes the game
      </h2>
      <p class="mx-auto mt-5 max-w-[48ch] font-body text-[1.05rem] font-light leading-relaxed text-soft">
        Godot, GameMaker and Unity are made for humans clicking through an editor — GUIs, binary
        scene files, a bespoke language. An agent can't diff a scene it can't read. Hayao keeps
        Godot's proven model — nodes, scenes, signals — but makes every part
        <span class="text-ink">text, typed and greppable</span>. The whole game is code your AI can
        write, read back, and reason about.
      </p>
    </section>

    <!-- ── DETERMINISTIC ── -->
    <section class="mx-auto max-w-2xl px-6 py-20 md:py-24">
      <p class="mb-4 font-body text-[0.75rem] uppercase tracking-[0.2em] text-blue">Deterministic</p>
      <h2 class="mx-auto max-w-[20ch] text-balance font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-ink">
        The game is a pure function of its inputs
      </h2>
      <p class="mx-auto mt-5 max-w-[48ch] font-body text-[1.05rem] font-light leading-relaxed text-soft">
        Every frame is <span class="text-ink">state → step(inputs) → state</span>. All randomness
        flows through one seeded RNG; there is no wall-clock and no hidden state. Same inputs, same
        result — bit for bit, on any machine. That one guarantee is where the superpowers come from.
      </p>

      <div class="mx-auto mt-8 max-w-md overflow-x-auto rounded-2xl border border-hair bg-[#0f1424] p-5 text-left">
        <pre class="font-mono text-[0.8rem] leading-relaxed text-[#d7dcec]"><code><span class="text-[#8ea1c7]">const</span> w = createWorld(game);
w.step([<span class="text-[#9cc98a]">'right'</span>]);   <span class="text-[#6b769b]">// advance one tick</span>
w.step([]);          <span class="text-[#6b769b]">// release</span>

w.probe().solved;    <span class="text-[#6b769b]">// assert on STATE</span>
<span class="text-[#8ea1c7]">const</span> h = w.hash(); <span class="text-[#6b769b]">// replay → same hash</span></code></pre>
      </div>

      <div class="mx-auto mt-12 flex max-w-sm flex-col gap-7">
        {
          benefits.map((b) => (
            <div>
              <div class:list={["mx-auto mb-2 h-1 w-8 rounded-full", dot[b.c as keyof typeof dot]]} />
              <h3 class="font-display text-[1.05rem] font-semibold text-ink">{b.t}</h3>
              <p class="mx-auto mt-1 max-w-[40ch] font-body text-[0.95rem] font-light leading-relaxed text-soft">
                {b.d}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ── SCENE TREE ── -->
    <section class="mx-auto max-w-2xl px-6 py-20 md:py-24">
      <p class="mb-4 font-body text-[0.75rem] uppercase tracking-[0.2em] text-green">Scene tree</p>
      <h2 class="mx-auto max-w-[20ch] text-balance font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-ink">
        Godot's scene tree, in plain code
      </h2>
      <p class="mx-auto mt-5 max-w-[48ch] font-body text-[1.05rem] font-light leading-relaxed text-soft">
        Compose your game from nodes — the model Godot got right. Node2D, Sprite, Camera2D, Timer,
        AnimationPlayer and behaviours: a tree you build in TypeScript, not a binary you edit in a
        GUI. Rendering is just a projection of that tree, so the simulation never needs a canvas.
      </p>
      <div class="mx-auto mt-8 inline-block overflow-x-auto rounded-2xl border border-hair bg-[#f8f9fb] p-5 text-left">
        <pre class="font-mono text-[0.9rem] leading-relaxed text-muted"><code>World
└─ <span class="text-blue">Node2D</span> <span class="text-ink">player</span>
   ├─ <span class="text-blue">Sprite</span> <span class="text-ink">body</span>
   ├─ <span class="text-blue">Camera2D</span> <span class="text-ink">follow</span>
   ├─ <span class="text-blue">AnimationPlayer</span> <span class="text-ink">run</span>
   └─ <span class="text-blue">Timer</span> <span class="text-ink">coyote</span></code></pre>
      </div>
    </section>

    <!-- ── OPEN SOURCE (band) ── -->
    <section class="w-full bg-navy py-20 md:py-24">
      <div class="mx-auto max-w-2xl px-6">
        <p class="mb-4 font-body text-[0.75rem] uppercase tracking-[0.2em] text-orange">Free &amp; open source</p>
        <h2 class="mx-auto max-w-[20ch] text-balance font-display text-[clamp(1.7rem,4vw,2.5rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-white">
          MIT-licensed. Yours to jam with.
        </h2>
        <p class="mx-auto mt-6 max-w-[52ch] font-body text-[1.1rem] font-light leading-relaxed text-white/70">
          No seats, no runtime fees, no strings. Winnability and determinism are proven before your
          deadline, and the whole engine is text your agent already speaks — perfect for a weekend jam.
        </p>
        <div class="mt-8 flex justify-center">
          <a
            href="https://github.com/hellojanpacan/hayao-js"
            class="inline-flex items-center rounded-full bg-orange px-6 py-3 font-body text-[0.95rem] font-semibold text-white no-underline transition-colors hover:bg-green"
          >
            Star on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- ── ASSETS AS CODE ── -->
    <section class="mx-auto max-w-2xl px-6 py-20 md:py-24">
      <p class="mb-4 font-body text-[0.75rem] uppercase tracking-[0.2em] text-blue">Assets as code</p>
      <h2 class="mx-auto max-w-[20ch] text-balance font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-ink">
        Art your agent can actually make
      </h2>
      <p class="mx-auto mt-5 max-w-[48ch] font-body text-[1.05rem] font-light leading-relaxed text-soft">
        An AI can't paint a PNG — but it can write vectors. Hayao's art is code: palettes, shapes,
        procedural textures, bitmap fonts and autotiling, all rendered crisp to SVG or Canvas. And
        the look is cosmetic and deterministic — it paints the state, it never changes it.
      </p>
      <div class="mx-auto mt-8 max-w-sm overflow-hidden rounded-2xl border border-hair">
        <svg viewBox="0 0 360 200" class="w-full" role="img" aria-label="Vector art drawn from code">
          <rect width="360" height="200" fill="#ffffff"></rect>
          <circle cx="280" cy="58" r="26" fill="#e59500"></circle>
          <path d="M0 142 Q90 104 180 134 T360 126 V200 H0 Z" fill="#669bbc"></path>
          <path d="M0 166 Q110 130 220 160 T360 154 V200 H0 Z" fill="#337357"></path>
          <rect x="150" y="114" width="13" height="13" rx="3" fill="#29335c"></rect>
        </svg>
        <div class="flex items-center justify-center gap-3 border-t border-hair px-5 py-3">
          <span class="flex gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-green"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-navy"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-orange"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-blue"></span>
          </span>
          <span class="font-mono text-[0.8rem] text-muted">code → SVG / Canvas</span>
        </div>
      </div>
    </section>

    <!-- ── CLOSING ── -->
    <section class="mx-auto max-w-2xl px-6 pt-16 pb-28 md:pt-20">
      <h2 class="mx-auto max-w-[16ch] text-balance font-display text-[clamp(1.9rem,5vw,2.8rem)] font-semibold leading-[1.08] tracking-[-0.015em] text-ink">
        Build your first game this weekend
      </h2>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/play"
          class="inline-flex items-center rounded-full bg-orange px-6 py-3 font-body text-[0.95rem] font-semibold text-white no-underline transition-colors hover:bg-green"
        >
          Playground
        </a>
        <InstallBox />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
