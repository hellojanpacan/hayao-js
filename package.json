{
  "name": "hayao",
  "version": "0.2.0",
  "type": "module",
  "description": "An AI-first game engine: a deterministic, headless-native simulation kernel with a Godot-style scene tree, pluggable renderers (SVG/Canvas/headless), and a built-in verification harness — designed so an LLM can author, test, and prove correct a whole game without ever opening a browser.",
  "keywords": [
    "game-engine",
    "ai-first",
    "deterministic",
    "typescript",
    "svg",
    "godot-like",
    "headless",
    "simulation"
  ],
  "author": "hellojanpacan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hellojanpacan/hayao-js.git"
  },
  "homepage": "https://hayao.dev/",
  "bugs": {
    "url": "https://github.com/hellojanpacan/hayao-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-hayao": "./bin/create-hayao.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "docs/QUICKSTART.md",
    "docs/API.md",
    "docs/VERIFICATION.md",
    "docs/CONVENTIONS.md",
    "docs/EMBED.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --platform=neutral --target=es2022 --outfile=dist/index.js --sourcemap && esbuild src/index.ts --bundle --minify --format=esm --platform=neutral --target=es2022 --outfile=dist/index.min.js && esbuild src/index.ts --bundle --minify --format=iife --global-name=hayao --platform=neutral --target=es2022 --outfile=dist/hayao.global.js && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "api": "tsx scripts/api-digest.ts",
    "invariants": "tsx scripts/invariants.ts",
    "verify": "tsx scripts/verify-all.ts",
    "eval": "tsx scripts/eval.ts",
    "create": "node bin/create-hayao.mjs",
    "prepublishOnly": "npm run check && npm test && npm run build:lib",
    "relay": "node scripts/relay.mjs",
    "palette": "tsx scripts/palette-audit.ts",
    "audio": "tsx scripts/audio-render.ts",
    "feel": "tsx scripts/feel.ts",
    "judge": "tsx scripts/judge.ts",
    "thumbs": "tsx scripts/site-thumbs.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "leva": "^0.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
